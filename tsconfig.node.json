{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "outDir": "./dist",
    "declarationDir": "./dist",
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["src/plugin.ts", "src/plugin/**/*.ts", "src/banner.ts", "src/module-shims.d.ts", "vite.config.ts", "tailwind.preset.ts"]
}
